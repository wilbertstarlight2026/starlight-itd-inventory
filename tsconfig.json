{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@starlight/shared": ["./shared/types/index.ts"]
    },
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true
  },
  "include": ["api/**/*", "apps/backend/src/**/*", "shared/types/**/*"],
  "exclude": ["node_modules", "apps/mobile", "apps/web-admin"]
}
